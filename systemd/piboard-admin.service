[Unit]
Description=PiBoard Kiosk Admin
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/piboard-kiosk
ExecStart=/opt/piboard-kiosk/venv/bin/uvicorn piboard_kiosk.app:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
